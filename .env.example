# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Path to your teammate's service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/your-service-account-key.json

# Firestore settings (defaults match teammate's setup)
FIRESTORE_DATABASE=capstonedb
FIRESTORE_COLLECTION=internship

# MCP server settings
DISABLE_AUTH=true
PORT=8080
